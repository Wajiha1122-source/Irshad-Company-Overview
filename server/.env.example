# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (Neon PostgreSQL)
DATABASE_URL=postgresql://username:password@host/database?sslmode=require

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Master Dashboard SSO
# Change SSO_SECRET here when rotating the shared Master Dashboard SSO secret.
SSO_SECRET=fjgroup-master-sso-shared-secret-2026-change-later
# Change SSO_APP_NAME only if the Master Dashboard sends a different exact app value.
SSO_APP_NAME=Irshad-Company-Overview
# Change SSO_LOCAL_CEO_USERNAME if the mapped local CEO/admin username changes.
SSO_LOCAL_CEO_USERNAME=admin
# Change SSO_REDIRECT_PATH if the CEO/admin landing page changes.
SSO_REDIRECT_PATH=/dashboard
